# Print the movie ratings greater than 6 using while loop

movie_rating = [8.0, 7.5, 5.4, 9.1, 6.3, 6.5, 2.1, 4.8, 3.3]

i = 0
while i < len(movie_rating):
    if movie_rating[i] > 6:
        print(movie_rating[i])
    i += 1

# Adding elements from one list to a new list using while loop

fruits = ['banana', 'apple', 'banana', 'orange', 'kiwi', 'banana', 'Cherry', 'Grapes']
new_list = []

i = 0
while i < len(fruits):
    new_list.append(fruits[i])
    i += 1

print(new_list)

